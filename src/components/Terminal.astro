---
interface Props {
  title?: string;
}

// const { title = "BLADE RUNNER TERMINAL v1.0" } = Astro.props;
---

<div class="terminal-container">
  <div class="terminal-screen crt-flicker">
    <div class="terminal-header">
      <button
        id="header-toggle"
        type="button"
        class="header-toggle menu-item mb-2 w-full text-left text-xs sm:hidden"
        aria-expanded="false"
        aria-controls="ascii-header-panel"
      >
        ▸ NEXUS-7 Terminal
      </button>
      <!-- ASCII Art Header -->
      <div
        id="ascii-header-panel"
        class="ascii-header text-terminal-bright mb-4 hidden text-center sm:block"
      >
        <div class="ascii-title">
